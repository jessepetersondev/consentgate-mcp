{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.jessepetersondev/consentgate-mcp",
  "description": "Gate AI agent actions behind a consent policy with human approval via Telegram. Fail-closed.",
  "repository": {
    "url": "https://github.com/jessepetersondev/consentgate-mcp",
    "source": "github"
  },
  "version": "0.1.1",
  "websiteUrl": "https://consentgate.fyi",
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "consentgate-mcp",
      "version": "0.1.1",
      "transport": { "type": "stdio" },
      "environmentVariables": [
        {
          "name": "CONSENTGATE_API_KEY",
          "description": "ConsentGate API key (cg_…) from https://consentgate.fyi/dashboard/keys",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "CONSENTGATE_BASE_URL",
          "description": "Override the API base URL (defaults to https://consentgate.fyi)",
          "isRequired": false
        }
      ]
    }
  ]
}
